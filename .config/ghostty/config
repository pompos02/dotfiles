term = xterm-256color

# Font Configuration
font-family = "TX02"
# font-style = Light
font-style-bold = Bold
# font-style-italic = "Light Oblique"
# font-style-bold-italic = Oblique
font-size = 15.0

# Previous font options (commented out)
#MonaspiceKr Nerd Font Mono
